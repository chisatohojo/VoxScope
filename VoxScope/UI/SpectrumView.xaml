<UserControl x:Class="VoxScope.UI.SpectrumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="240"
             SizeChanged="SpectrumView_SizeChanged">
    <Border BorderBrush="#D1D5DB"
            BorderThickness="1"
            CornerRadius="6"
            Background="#FFFFFF">
        <Canvas x:Name="PlotCanvas"
                ClipToBounds="True" />
    </Border>
</UserControl>
