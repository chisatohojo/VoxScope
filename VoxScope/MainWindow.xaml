<Window x:Class="VoxScope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoxScope"
        xmlns:ui="clr-namespace:VoxScope.UI"
        mc:Ignorable="d"
        Title="VoxScope"
        Height="900"
        Width="1100"
        MinHeight="860"
        MinWidth="1020"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="320" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Text="VoxScope" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="入力デバイス" />

            <ComboBox x:Name="InputDeviceComboBox"
                      Grid.Column="1"
                      Height="32"
                      DisplayMemberPath="DisplayName" />
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="出力デバイス" />

            <ComboBox x:Name="OutputDeviceComboBox"
                      Grid.Column="1"
                      Height="32"
                      DisplayMemberPath="DisplayName" />
        </Grid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal">
            <Button x:Name="StartStopButton"
                    Width="120"
                    Height="36"
                    Click="StartStopButton_Click"
                    Content="Start" />

            <Button x:Name="RefreshDevicesButton"
                    Width="120"
                    Height="36"
                    Margin="12,0,0,0"
                    Click="RefreshDevicesButton_Click"
                    Content="再読み込み" />
        </StackPanel>

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="解析表示" />

                <ui:SpectrumView x:Name="SpectrumView"
                                 Margin="0,12,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="現在値" />

                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="入力F0" />
                    <TextBlock x:Name="InputPitchTextBlock"
                               Grid.Column="1"
                               HorizontalAlignment="Right" />

                    <TextBlock Grid.Row="2"
                               Text="入力F0平均" />
                    <TextBlock x:Name="InputAveragePitchTextBlock"
                               Grid.Row="2"
                               Grid.Column="1"
                               HorizontalAlignment="Right" />

                    <TextBlock Grid.Row="4"
                               Text="出力F0" />
                    <TextBlock x:Name="OutputPitchTextBlock"
                               Grid.Row="4"
                               Grid.Column="1"
                               HorizontalAlignment="Right" />

                    <TextBlock Grid.Row="6"
                               Text="出力F0平均" />
                    <TextBlock x:Name="OutputAveragePitchTextBlock"
                               Grid.Row="6"
                               Grid.Column="1"
                               HorizontalAlignment="Right" />

                    <TextBlock Grid.Row="8"
                               Text="ゲート状態" />
                    <TextBlock x:Name="GateOpenTextBlock"
                               Grid.Row="8"
                               Grid.Column="1"
                               HorizontalAlignment="Right" />

                    <TextBlock Grid.Row="10"
                               Text="F0目安" />
                    <TextBlock Grid.Row="10"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               Text="低め 90-155 / 高め 165-255 Hz" />
                </Grid>

                <ui:LevelMeter x:Name="InputLevelMeter"
                               Margin="0,22,0,0"
                               Title="入力レベル" />

                <ui:LevelMeter x:Name="OutputLevelMeter"
                               Margin="0,18,0,0"
                               Title="出力レベル" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="基本エフェクト" />

                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="128" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Pitch Shift" />
                    <Slider x:Name="PitchShiftSlider"
                            Grid.Row="0"
                            Grid.Column="1"
                            Minimum="-12"
                            Maximum="12"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="PitchShiftSlider_ValueChanged" />
                    <TextBlock x:Name="PitchShiftValueTextBlock"
                               Grid.Row="0"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="声の高さを上下に変えます。" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Output Gain" />
                    <Slider x:Name="OutputGainSlider"
                            Grid.Row="3"
                            Grid.Column="1"
                            Minimum="-24"
                            Maximum="12"
                            TickFrequency="1"
                            ValueChanged="OutputGainSlider_ValueChanged" />
                    <TextBlock x:Name="OutputGainValueTextBlock"
                               Grid.Row="3"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="最終的な出力音量を調整します。" />

                    <CheckBox x:Name="NoiseGateCheckBox"
                              Grid.Row="6"
                              Grid.ColumnSpan="2"
                              VerticalAlignment="Center"
                              Checked="NoiseGateCheckBox_Checked"
                              Unchecked="NoiseGateCheckBox_Checked"
                              Content="Noise Gate" />
                    <TextBlock x:Name="NoiseGateStateTextBlock"
                               Grid.Row="6"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="7"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="小さな環境音を抑えます。" />

                    <TextBlock Grid.Row="9"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Gate Threshold" />
                    <Slider x:Name="NoiseGateThresholdSlider"
                            Grid.Row="9"
                            Grid.Column="1"
                            Minimum="-80"
                            Maximum="-20"
                            Value="-45"
                            TickFrequency="1"
                            ValueChanged="NoiseGateThresholdSlider_ValueChanged" />
                    <TextBlock x:Name="NoiseGateThresholdValueTextBlock"
                               Grid.Row="9"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="10"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="どの小ささから無音扱いにするか決めます。" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="EQ" />

                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Low" />
                    <Slider x:Name="EqLowSlider"
                            Grid.Row="0"
                            Grid.Column="1"
                            Minimum="-12"
                            Maximum="12"
                            TickFrequency="1"
                            ValueChanged="EqLowSlider_ValueChanged" />
                    <TextBlock x:Name="EqLowValueTextBlock"
                               Grid.Row="0"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="低音の厚みを調整します。" />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Mid" />
                    <Slider x:Name="EqMidSlider"
                            Grid.Row="3"
                            Grid.Column="1"
                            Minimum="-12"
                            Maximum="12"
                            TickFrequency="1"
                            ValueChanged="EqMidSlider_ValueChanged" />
                    <TextBlock x:Name="EqMidValueTextBlock"
                               Grid.Row="3"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="声の中心帯域を調整します。" />

                    <TextBlock Grid.Row="6"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="High" />
                    <Slider x:Name="EqHighSlider"
                            Grid.Row="6"
                            Grid.Column="1"
                            Minimum="-12"
                            Maximum="12"
                            TickFrequency="1"
                            ValueChanged="EqHighSlider_ValueChanged" />
                    <TextBlock x:Name="EqHighValueTextBlock"
                               Grid.Row="6"
                               Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="7"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Foreground="#4B5563"
                               Text="明るさや抜け感を調整します。" />
                </Grid>
            </StackPanel>
        </Grid>

        <Border Grid.Row="12"
                Padding="12"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock x:Name="StatusTextBlock"
                           FontWeight="SemiBold"
                           Text="初期化中..." />
                <TextBlock x:Name="FormatTextBlock"
                           Margin="0,4,0,0"
                           Foreground="#4B5563"
                           Text="-" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
